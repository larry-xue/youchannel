GOOGLE_CLIENT_SECRET=

# Sync cron
SYNC_CRON_ENABLED=true
SYNC_CRON_SCHEDULE=*/1 * * * *
SYNC_CRON_TIMEZONE=UTC
SYNC_INTERVAL_MINUTES=20
SYNC_JITTER_SECONDS=120
JOBS_POLL_INTERVAL_MS=5000
JOBS_LEASE_SECONDS=300
JOBS_RETRY_DELAY_SECONDS=60
JOBS_TYPES=sync_playlist
